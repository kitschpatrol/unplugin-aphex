{
	"name": "unplugin-apple-photos",
	"version": "0.0.0",
	"description": "Description.",
	"keywords": [
		"unplugin",
		"vite",
		"webpack",
		"rspack",
		"rollup",
		"rolldown",
		"esbuild",
		"farm"
	],
	"homepage": "https://github.com/kitschpatrol/unplugin-apple-photos",
	"bugs": "https://github.com/kitschpatrol/unplugin-apple-photos/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/unplugin-apple-photos.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./*": "./*",
		"./api": "./dist/api.js",
		"./esbuild": "./dist/esbuild.js",
		"./farm": "./dist/farm.js",
		"./rolldown": "./dist/rolldown.js",
		"./rollup": "./dist/rollup.js",
		"./rspack": "./dist/rspack.js",
		"./vite": "./dist/vite.js",
		"./webpack": "./dist/webpack.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./*"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown --tsconfig tsconfig.build.json",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"dev": "tsdown --tsconfig tsconfig.build.json --watch",
		"fix": "kpi fix",
		"lint": "kpi lint",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && pnpm publish --otp $(op read 'op://Personal/Npmjs/one-time password?attribute=otp')",
		"test": "vitest"
	},
	"dependencies": {
		"unplugin": "^2.3.5",
		"unplugin-utils": "^0.2.4"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.4.2",
		"@sxzz/test-utils": "^0.5.6",
		"@types/node": "^22.15.21",
		"bumpp": "^10.1.1",
		"tsdown": "^0.12.3",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3",
		"vite": "^6.3.5",
		"vitest": "^3.1.4"
	},
	"packageManager": "pnpm@10.11.0",
	"engines": {
		"node": ">=18.12.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
