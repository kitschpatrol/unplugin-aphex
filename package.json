{
  "name": "unplugin-apple-photos",
  "version": "0.0.0",
  "packageManager": "pnpm@10.11.0",
  "description": "Description.",
  "type": "module",
  "keywords": [
    "unplugin",
    "vite",
    "webpack",
    "rspack",
    "rollup",
    "rolldown",
    "esbuild",
    "farm"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kitschpatrol/unplugin-apple-photos",
  "bugs": "https://github.com/kitschpatrol/unplugin-apple-photos/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitschpatrol/unplugin-apple-photos.git"
  },
  "author": {
    "name": "Eric Mika",
    "email": "eric@ericmika.com",
    "url": "https://ericmika.com"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./vite": "./dist/vite.js",
    "./webpack": "./dist/webpack.js",
    "./rspack": "./dist/rspack.js",
    "./rollup": "./dist/rollup.js",
    "./rolldown": "./dist/rolldown.js",
    "./esbuild": "./dist/esbuild.js",
    "./farm": "./dist/farm.js",
    "./api": "./dist/api.js",
    "./*": "./*"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "unplugin": "^2.3.5",
    "unplugin-utils": "^0.2.4"
  },
  "devDependencies": {
    "@sxzz/test-utils": "^0.5.6",
    "@types/node": "^22.15.21",
    "bumpp": "^10.1.1",
    "tsdown": "^0.12.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "engines": {
    "node": ">=18.12.0"
  }
}
