{
	"name": "@kitschpatrol/unplugin-aphex",
	"version": "0.0.0",
	"description": "Unplugin for module-style image imports from your macOS Photos.app library.",
	"keywords": [
		"photos",
		"aphex",
		"apple-photos",
		"unplugin",
		"vite",
		"webpack",
		"rspack",
		"rollup",
		"rolldown",
		"esbuild",
		"farm",
		"transform",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/unplugin-aphex",
	"bugs": "https://github.com/kitschpatrol/unplugin-aphex/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/unplugin-aphex.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./astro": "./dist/astro.js",
		"./esbuild": "./dist/esbuild.js",
		"./farm": "./dist/farm.js",
		"./nuxt": "./dist/nuxt.js",
		"./package.json": "./package.json",
		"./rolldown": "./dist/rolldown.js",
		"./rollup": "./dist/rollup.js",
		"./rspack": "./dist/rspack.js",
		"./types": "./dist/types.js",
		"./vite": "./dist/vite.js",
		"./webpack": "./dist/webpack.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./*"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown --no-fixed-extension",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"dev": "tsdown --watch",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"play": "poptab ; pnpm -C playground run dev",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest"
	},
	"dependencies": {
		"@kitschpatrol/aphex": "../aphex",
		"unplugin": "^2.3.10"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.8.1",
		"@nuxt/kit": "^4.2.0",
		"@nuxt/schema": "^4.2.0",
		"@types/node": "^22.19.0",
		"bumpp": "^10.3.1",
		"defu": "^6.1.4",
		"nodemon": "^3.1.10",
		"poptab": "^1.0.3",
		"rollup": "^4.52.5",
		"tsdown": "^0.15.12",
		"tsx": "^4.20.6",
		"typescript": "~5.9.3",
		"vite": "^7.2.1",
		"vite-plugin-mkcert": "^1.17.9",
		"vitest": "^3.2.4",
		"webpack": "^5.102.1"
	},
	"peerDependencies": {
		"@farmfe/core": ">=1",
		"@nuxt/kit": "^3",
		"@nuxt/schema": "^3",
		"esbuild": "*",
		"rollup": "^3",
		"vite": ">=3",
		"webpack": "^4 || ^5"
	},
	"peerDependenciesMeta": {
		"@farmfe/core": {
			"optional": true
		},
		"@nuxt/kit": {
			"optional": true
		},
		"@nuxt/schema": {
			"optional": true
		},
		"esbuild": {
			"optional": true
		},
		"rollup": {
			"optional": true
		},
		"vite": {
			"optional": true
		},
		"webpack": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.20.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"os": [
		"darwin"
	],
	"cpu": [
		"arm64"
	],
	"publishConfig": {
		"access": "public"
	}
}
