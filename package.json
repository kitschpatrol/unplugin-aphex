{
	"name": "unplugin-aphex",
	"version": "0.0.0",
	"description": "Unplugin for module-style image imports from your macOS Photos.app library.",
	"keywords": [
		"photos",
		"aphex",
		"apple-photos",
		"unplugin",
		"vite",
		"webpack",
		"rspack",
		"rollup",
		"rolldown",
		"esbuild",
		"farm",
		"transform"
	],
	"homepage": "https://github.com/kitschpatrol/unplugin-aphex",
	"bugs": "https://github.com/kitschpatrol/unplugin-aphex/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/unplugin-aphex.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./*": "./*",
		"./api": "./dist/api.js",
		"./astro": "./dist/astro.js",
		"./esbuild": "./dist/esbuild.js",
		"./farm": "./dist/farm.js",
		"./nuxt": "./dist/nuxt.js",
		"./package.json": "./package.json",
		"./rolldown": "./dist/rolldown.js",
		"./rollup": "./dist/rollup.js",
		"./rspack": "./dist/rspack.js",
		"./types": "./dist/types.js",
		"./vite": "./dist/vite.js",
		"./webpack": "./dist/webpack.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./*"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"dev": "tsdown --watch",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"play": "npm -C playground run dev",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && pnpm publish --otp $(op read 'op://Personal/Npmjs/one-time password?attribute=otp')",
		"test": "vitest"
	},
	"dependencies": {
		"aphex": "../aphex",
		"unplugin": "^2.3.10"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.7.0",
		"@nuxt/kit": "^4.1.2",
		"@nuxt/schema": "^4.1.2",
		"@types/node": "^20.19.17",
		"bumpp": "^10.2.3",
		"defu": "^6.1.4",
		"nodemon": "^3.1.10",
		"rollup": "^4.50.2",
		"tsdown": "^0.15.2",
		"tsx": "^4.20.5",
		"typescript": "~5.9.2",
		"vite": "^7.1.6",
		"vitest": "^3.2.4",
		"webpack": "^5.101.3"
	},
	"peerDependencies": {
		"@farmfe/core": ">=1",
		"@nuxt/kit": "^3",
		"@nuxt/schema": "^3",
		"esbuild": "*",
		"rollup": "^3",
		"vite": ">=3",
		"webpack": "^4 || ^5"
	},
	"peerDependenciesMeta": {
		"@farmfe/core": {
			"optional": true
		},
		"@nuxt/kit": {
			"optional": true
		},
		"@nuxt/schema": {
			"optional": true
		},
		"esbuild": {
			"optional": true
		},
		"rollup": {
			"optional": true
		},
		"vite": {
			"optional": true
		},
		"webpack": {
			"optional": true
		}
	},
	"packageManager": "pnpm@10.17.0",
	"engines": {
		"node": ">=20.19.0"
	},
	"os": [
		"darwin"
	],
	"cpu": [
		"arm64"
	],
	"publishConfig": {
		"access": "public"
	}
}
