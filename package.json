{
	"name": "@kitschpatrol/unplugin-aphex",
	"version": "0.0.0",
	"description": "Unplugin for module-style image imports from your macOS Photos.app library.",
	"keywords": [
		"photos",
		"aphex",
		"apple-photos",
		"unplugin",
		"vite",
		"webpack",
		"rspack",
		"rollup",
		"rolldown",
		"esbuild",
		"farm",
		"transform",
		"npm-package"
	],
	"homepage": "https://github.com/kitschpatrol/unplugin-aphex",
	"bugs": "https://github.com/kitschpatrol/unplugin-aphex/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/unplugin-aphex.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"type": "module",
	"exports": {
		".": "./dist/index.js",
		"./*": "./*",
		"./api": "./dist/api.js",
		"./client": {
			"types": "./dist/client.d.ts"
		},
		"./esbuild": "./dist/esbuild.js",
		"./farm": "./dist/farm.js",
		"./rolldown": "./dist/rolldown.js",
		"./rollup": "./dist/rollup.js",
		"./rspack": "./dist/rspack.js",
		"./vite": "./dist/vite.js",
		"./webpack": "./dist/webpack.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"typesVersions": {
		"*": {
			"*": [
				"./dist/*",
				"./*"
			]
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"clean": "git rm -f pnpm-lock.yaml ; git clean -fdX",
		"dev": "tsdown --watch",
		"fix": "ksc fix",
		"lint": "ksc lint",
		"play": "poptab ; pnpm -C playground run dev",
		"release": "bumpp --commit 'Release: %s' && pnpm run build && NPM_AUTH_TOKEN=$(op read 'op://Personal/npm/token') && pnpm publish",
		"test": "vitest"
	},
	"dependencies": {
		"@kitschpatrol/aphex": "file:../aphex",
		"@types/node": "~22.16.5",
		"defu": "^6.1.4",
		"unplugin": "^2.3.10",
		"unplugin-utils": "^0.3.1"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^5.8.3",
		"@sxzz/test-utils": "^0.5.12",
		"@vitest/browser-playwright": "^4.0.8",
		"bumpp": "^10.3.1",
		"poptab": "^1.0.3",
		"tsdown": "^0.16.1",
		"type-fest": "^5.2.0",
		"typescript": "~5.9.3",
		"vitest": "^4.0.8"
	},
	"packageManager": "pnpm@10.21.0",
	"engines": {
		"node": ">=22.16.0"
	},
	"os": [
		"darwin"
	],
	"cpu": [
		"arm64"
	],
	"publishConfig": {
		"access": "public"
	}
}
